# ─────────────────────────────────────────────────────────
# Mission Control — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Database (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_cpanel_user_dbuser
DB_PASSWORD=your_password
DB_NAME=your_cpanel_user_missioncontrol

# Docker-specific (used by docker-compose)
DB_ROOT_PASSWORD=changeme_root_password

# Application
PORT=5000
NODE_ENV=production
